+    def _run_checker_or_bypass(
+        self,
+        codes: list[str],
+        transcript_text: str,
+        evidence_map,
+        lang: str,
+        include_per_disorder_variants: bool,
+    ) -> list[CheckerOutput]:
+        """Route to real checker OR synthesize all-criteria-met CheckerOutputs.
+
+        R17 ablation: when self._bypass_checker is True, skip the LLM checker
+        entirely. Synthesize CheckerOutput objects with every criterion marked
+        status="met" so the logic engine trivially confirms every candidate.
+
+        This makes primary selection fall through to the diagnostician's top-1
+        ranking — isolating the checker's contribution to Top-1 accuracy.
+        Used by both non-DtV (Stage 2) and DtV (verify + remaining) code paths.
+        """
+        if getattr(self, "_bypass_checker", False):
+            from culturedx.core.models import CriterionResult
+            from culturedx.ontology.icd10 import get_disorder_criteria
+
+            outputs = []
+            for code in codes:
+                criteria_def = get_disorder_criteria(code)
+                if not criteria_def:
+                    continue
+                crit_ids = list(criteria_def.keys())
+                synthetic = [
+                    CriterionResult(
+                        criterion_id=cid,
+                        status="met",
+                        evidence="[R17: checker_bypassed]",
+                        confidence=1.0,
+                    )
+                    for cid in crit_ids
+                ]
+                outputs.append(
+                    CheckerOutput(
+                        disorder=code,
+                        criteria=synthetic,
+                        criteria_met_count=len(crit_ids),
+                        criteria_required=len(crit_ids),
+                    )
+                )
+            return outputs
+
+        # Normal path: invoke real LLM checker
+        kwargs = dict(
+            checker=self.checker,
+            codes=codes,
+            transcript_text=transcript_text,
+            evidence_map=evidence_map,
+            lang=lang,
+            prompt_variant=self._effective_checker_variant,
+            checker_llm_client=self.checker_llm,
+        )
+        # The non-DtV and DtV-verify paths pass per_disorder_variants;
+        # the DtV-remaining path does not.
+        call_args = [
+            self.checker,
+            codes,
+            transcript_text,
+            evidence_map,
+            lang,
+        ]
+        call_kwargs = {
+            "prompt_variant": self._effective_checker_variant,
+            "checker_llm_client": self.checker_llm,
+        }
+        if include_per_disorder_variants:
+            call_kwargs["per_disorder_variants"] = self._per_disorder_checker_variants
+        return self._parallel_check_criteria(*call_args, **call_kwargs)
